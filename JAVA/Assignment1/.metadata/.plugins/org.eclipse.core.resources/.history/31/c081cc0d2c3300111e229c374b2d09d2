
public class Date {
	private int day;
	private int month;
	private int year;
	
	public void setDate(int d, int m, int y)
	{
		day = d;
		month = m;
		year = y;
	}
	
	public int getDate()
	{
		return day;
	}
	
	public static void main(String args[])
	{
		day d = new day();
		d.setDate(8);
		System.out.println("Day = "d.getDate());
		
		//System.out.println("Day is "+day);
		
	}
}
