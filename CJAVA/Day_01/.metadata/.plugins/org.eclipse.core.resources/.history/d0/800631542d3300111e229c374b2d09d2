
public class Date {
	private int Day;
	private int Month;
	private int Year;
	
	public void setDay(int d)
	{
		Day = d;
	}
	
	public void setMonth(int m)
	{
		Month = m;
	}
	
	public void setYear(int y)
	{
		Year = y;
	}
	
	public int getDay()
	{
		return Day;
	}
	
	public int getMonth()
	{
		return Month;
	}
	
	public int getYear()
	{
		return Year;
	}
	
	public static void main(String args[])
	{
		Day d = new Day();
		d.setDay(8);
		System.out.println("Day = "+d.getDate());
		
		//System.out.println("Day is "+day);
		
	}
}
