
public class Player {
	private String playerName;
	private String playerCountry;
	
	public Player()
	{
		playerCountry = "India";
	}
	
	public Player(String playerName)
	{
		this();
		this.playerName = playerName;
	}
	
	
	public String toString()
	{
		return "Player [Playername = "+playerName+ "playerCountry = "+playerCountry;
	}
	
}
